# ComfyUI Horror-Painting Server — app image (code only, models in base).
# Builds in seconds. Rebuild on every code/workflow change.
#
# Requires base image to exist first:
#   docker buildx build --platform linux/amd64 \
#     --build-arg CIVITAI_TOKEN=<token> \
#     -f services/comfyui-vast/Dockerfile.base \
#     -t ghcr.io/sgoel1220/comfyui-vast-base:latest --push .
#
# Then build app image:
#   docker buildx build --platform linux/amd64 \
#     -f services/comfyui-vast/Dockerfile.baked \
#     -t ghcr.io/sgoel1220/comfyui-vast:main --push .

FROM ghcr.io/sgoel1220/comfyui-vast-base:latest
# Note: base image is built first by CI (build-and-push job), this job runs after (needs: build-and-push)

# ---------------------------------------------------------------------------
# App files — the only layer that changes between deploys
# ---------------------------------------------------------------------------

COPY services/comfyui-serverless-vast/workflow_api.json /app/workflow_api.json
COPY services/comfyui-serverless-vast/server.py /app/server.py
COPY services/comfyui-vast/start.sh /app/start.sh

RUN chmod +x /app/start.sh

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------

EXPOSE 8006

HEALTHCHECK --interval=30s --timeout=10s --start-period=300s --retries=3 \
    CMD curl -fsS http://127.0.0.1:8006/ready >/dev/null || exit 1

CMD ["/app/start.sh"]
