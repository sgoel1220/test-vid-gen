# Copy to .env and fill in real values before running.

# Async Postgres DSN (used by the app and alembic).
DATABASE_URL=postgresql+asyncpg://metadata:changeme@localhost:5432/metadata

# Bearer token the Pod must send in Authorization: Bearer <token>
METADATA_API_KEY=change_me_to_a_long_random_secret

# Filesystem root for audio blob storage.
AUDIO_STORAGE_ROOT=/data/audio

# Server listen address.
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8080

# For docker-compose postgres service password (must match DATABASE_URL).
POSTGRES_PASSWORD=changeme
