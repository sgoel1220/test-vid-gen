# Creepy Brain Service - Environment Variables
# Copy this file to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=8006
RELOAD=false
DEV_MODE=false  # Set to true to enable dev-only endpoints (e.g. POST /api/workflows/test)

# Logging: false for pretty dev logs, true for production JSON
JSON_LOGS=false

# PostgreSQL
# When using docker-compose: POSTGRES_HOST=localhost, POSTGRES_PORT=5433 (mapped host port)
# When running inside Docker network: POSTGRES_HOST=postgres, POSTGRES_PORT=5432
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=creepy_brain
POSTGRES_PASSWORD=dev_password
POSTGRES_DB=creepy_brain

# LLM provider: "anthropic" or "openrouter"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
# For Anthropic: claude-opus-4-6  |  For OpenRouter: anthropic/claude-opus-4-6
LLM_MODEL=claude-opus-4-6

# GPU Provider (RunPod)
RUNPOD_API_KEY=your_runpod_api_key_here

# Concurrency
MAX_CONCURRENT_GENERATIONS=2
